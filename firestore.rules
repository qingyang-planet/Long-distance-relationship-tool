rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isCoupleMember(coupleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId)/members/$(request.auth.uid));
    }

    function coupleMemberCount(data) {
      return data.keys().hasAll(['memberCount']) ? data.memberCount : 1;
    }

    function coupleHasRoom(coupleId) {
      return coupleMemberCount(get(/databases/$(database)/documents/couples/$(coupleId)).data) < 2;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /couples/{coupleId} {
      // 登录用户可读（加入空间时需要查 memberCount）
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // 成员可更新；加入时仅允许 memberCount +1
      allow update: if isCoupleMember(coupleId)
        || (isSignedIn()
            && coupleMemberCount(resource.data) < 2
            && request.resource.data.memberCount == coupleMemberCount(resource.data) + 1
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']));

      match /members/{memberId} {
        allow read: if isCoupleMember(coupleId);
        // 加入空间：只能创建自己的成员文档，且空间未满
        allow create: if isSignedIn()
          && request.auth.uid == memberId
          && coupleHasRoom(coupleId);
        allow update: if isCoupleMember(coupleId) && request.auth.uid == memberId;
      }

      match /meeting/{docId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      match /wishes/{wishId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      match /dailyThink/{docId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      match /thinkEvents/{eventId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
          && request.resource.data.senderId == request.auth.uid;
      }

      match /letters/{letterId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
